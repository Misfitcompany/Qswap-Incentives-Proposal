+	struct END_EPOCH_locals
+	{
+		Entity entity;
+		PoolBasicState p;
+		Array<uint32, QSWAP_INCENTIVE_HIST_BUCKETS> bucketCount;
+		uint64 balance;
+		uint64 totalReserved;
+		uint64 undistFees;
+		uint64 stray;
+		uint64 maxVol;
+		uint64 qualVol;
+		uint64 distributed;
+		uint64 poolShare;
