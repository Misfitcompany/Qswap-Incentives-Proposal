+// the core: sweep stray QU, drop bottom 30% by volume, split the rest volume-weighted
+TEST(ContractSwap, Incentive_SweepWeightedDistribution_BottomExcluded)
+{
+    ContractTestingQswap qswap;
+    id issuer(1, 2, 3, 4);
+    id user(5, 6, 7, 8);
+    uint64 nA = assetNameFromString("POOLA"), nB = assetNameFromString("POOLB");
+    uint64 nC = assetNameFromString("POOLC"), nD = assetNameFromString("POOLD");
+    sint64 numShares = 100000 * 1000, assetAmt = 100 * 1000, quAmt = 200 * 1000;
+    qswap.setupPoolWithLiquidity(issuer, nA, numShares, assetAmt, quAmt);
+    qswap.setupPoolWithLiquidity(issuer, nB, numShares, assetAmt, quAmt);
+    qswap.setupPoolWithLiquidity(issuer, nC, numShares, assetAmt, quAmt);
+    qswap.setupPoolWithLiquidity(issuer, nD, numShares, assetAmt, quAmt);
+
+    qswap.swapQuIn(user, issuer, nA, 300 * 1000);  // volumes 300k/200k/100k/10k
+    qswap.swapQuIn(user, issuer, nB, 200 * 1000);
+    qswap.swapQuIn(user, issuer, nC, 100 * 1000);
+    qswap.swapQuIn(user, issuer, nD, 10 * 1000);
+
+    sint64 stray = 6 * 1000 * 1000;
+    increaseEnergy(QSWAP_CONTRACT_ID, stray);
+    uint64 lifeBefore = qswap.getState()->mIncentiveLifetimeDistributed;
+    qswap.endEpoch();
+    uint64 distributed = qswap.getState()->mIncentiveLifetimeDistributed - lifeBefore;
+
+    // bottom pool D (10k vs 100-300k): 4 pools -> exclude floor(4*0.3)=1 -> D gets nothing
+    EXPECT_EQ(qswap.getClaimableIncentive(issuer, nD, issuer).accIncentivePerLP, (uint64)0);
+    EXPECT_EQ(qswap.getClaimableIncentive(issuer, nD, issuer).claimableQu, (sint64)0);
+
+    sint64 clA = qswap.getClaimableIncentive(issuer, nA, issuer).claimableQu;
+    sint64 clB = qswap.getClaimableIncentive(issuer, nB, issuer).claimableQu;
+    sint64 clC = qswap.getClaimableIncentive(issuer, nC, issuer).claimableQu;
+    EXPECT_GT(clA, clB);
+    EXPECT_GT(clB, clC);
+    EXPECT_GT(clC, 0);
+    EXPECT_NEAR((double)clA / (double)clC, 3.0, 0.05);   // weighted 300:200:100 = 3:2:1
+    EXPECT_NEAR((double)clB / (double)clC, 2.0, 0.05);
+    EXPECT_GE(distributed, (uint64)(stray - 10));         // ~all distributed (dust < #pools)
+    EXPECT_LE(distributed, (uint64)stray);
+    EXPECT_GT(clA + clB + clC, (sint64)((double)distributed * 0.98));
+    EXPECT_LE(clA + clB + clC, (sint64)distributed);
+
+    EXPECT_EQ(qswap.getClaimableIncentive(issuer, nA, issuer).poolVolumeEpoch, (uint64)0);  // volumes reset
+}
